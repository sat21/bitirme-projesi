# Note: already tracked files remain tracked.
*.zip
checkpoints_*/**/tensorboard/
checkpoints_*/**/logs/
checkpoints_*/**/events.out.tfevents*
checkpoints_*/**/*.tmp
checkpoints_*/**/*.bak
artifacts/**/tmp/
artifacts/**/cache/
artifacts/**/runs/
artifacts/**/*.npy
artifacts/**/*.npz
