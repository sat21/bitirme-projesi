# Local virtual environments
.venv/
.venv-1/
tf1env/
shufflenet-v2-tensorflow/venv/

# Editor / OS metadata
.vscode/
**/.DS_Store

# Python cache
**/__pycache__/
**/*.pyc
**/.ipynb_checkpoints/

